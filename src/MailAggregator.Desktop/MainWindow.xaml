<Window x:Class="MailAggregator.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MailAggregator.Desktop.ViewModels"
        Title="MailAggregator" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Top Toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Band="0" BandIndex="0">
                <Button Content="Unified Inbox" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ShowUnifiedInboxCommand}" />
                <Separator />
                <Button Content="New Mail" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ComposeNewCommand}" />
                <Button Content="Reply" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ReplyCommand}" />
                <Button Content="Reply All" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ReplyAllCommand}" />
                <Button Content="Forward" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ForwardCommand}" />
                <Separator />
                <Button Content="Delete" Style="{StaticResource ToolbarButton}"
                        Command="{Binding DeleteMessageCommand}"
                        CommandParameter="{Binding SelectedEmail}" />
                <Separator />
                <Button Content="Sync" Style="{StaticResource ToolbarButton}"
                        Command="{Binding LoadAccountsCommand}" />
                <Separator />
                <Button Content="Accounts" Style="{StaticResource ToolbarButton}"
                        Command="{Binding OpenAccountSettingsCommand}" />
            </ToolBar>
        </ToolBarTray>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource StatusBarText}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="100" Height="14" IsIndeterminate="True"
                             Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVisibility}}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Main three-pane layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Left: Account/Folder tree -->
                <ColumnDefinition Width="220" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <!-- Right: Email list + Preview -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel: Folder tree -->
            <DockPanel Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <!-- Account filter -->
                <StackPanel DockPanel.Dock="Top" Margin="8">
                    <TextBlock Text="Accounts" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />
                </StackPanel>

                <TreeView x:Name="FolderTreeView" ItemsSource="{Binding FolderTree}"
                          BorderThickness="0" Background="Transparent" Padding="4">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayName}" Margin="2,0,4,0" />
                                <TextBlock Text="{Binding UnreadCount, StringFormat='({0})'}"
                                           Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold"
                                           Visibility="{Binding UnreadCount, Converter={StaticResource NullToVisibility}}" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="{StaticResource SeparatorBrush}" />

            <!-- Right panel: Email list + Preview -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1.5*" MinHeight="150" />
                </Grid.RowDefinitions>

                <!-- Email list -->
                <ListBox Grid.Row="0" ItemsSource="{Binding Emails}"
                         SelectedItem="{Binding SelectedEmail}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource EmailListItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Sender + Subject -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeight}}">
                                    <Run Text="{Binding FromName, Mode=OneWay}" />
                                    <Run Text=" &lt;" /><Run Text="{Binding FromAddress, Mode=OneWay}" /><Run Text="&gt;" />
                                </TextBlock>

                                <!-- Date -->
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding DateSent, StringFormat='{}{0:MM/dd HH:mm}'}"
                                           Foreground="{StaticResource ReadBrush}" FontSize="12"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />

                                <!-- Subject + Preview -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Foreground="{StaticResource ReadBrush}" FontSize="12"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0">
                                    <Run Text="{Binding Subject, Mode=OneWay}"
                                         FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeight}}" />
                                    <Run Text=" - " />
                                    <Run Text="{Binding PreviewText, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Horizontal splitter -->
                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                              VerticalAlignment="Center" Background="{StaticResource SeparatorBrush}" />

                <!-- Email preview -->
                <Border Grid.Row="2" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <!-- No email selected -->
                        <TextBlock Text="Select an email to preview"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource ReadBrush}" FontSize="14"
                                   Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibility}, ConverterParameter=Invert}" />

                        <!-- Email preview content -->
                        <DockPanel Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibility}}">
                            <!-- Email header -->
                            <Border DockPanel.Dock="Top" Padding="12,8" Background="#FAFAFA"
                                    BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedEmail.Subject}"
                                               FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource ReadBrush}">
                                        <Run Text="From: " />
                                        <Run Text="{Binding SelectedEmail.FromName, Mode=OneWay}" />
                                        <Run Text=" &lt;" /><Run Text="{Binding SelectedEmail.FromAddress, Mode=OneWay}" /><Run Text="&gt;" />
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{StaticResource ReadBrush}">
                                        <Run Text="To: " />
                                        <Run Text="{Binding SelectedEmail.ToAddresses, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{StaticResource ReadBrush}"
                                               Text="{Binding SelectedEmail.DateSent, StringFormat='Date: {0:yyyy-MM-dd HH:mm:ss}'}" />

                                    <!-- Attachments -->
                                    <ItemsControl ItemsSource="{Binding SelectedEmail.Attachments}"
                                                  Margin="0,4,0,0"
                                                  Visibility="{Binding SelectedEmail.HasAttachments, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource SeparatorBrush}"
                                                        BorderThickness="1" CornerRadius="3"
                                                        Padding="6,2" Margin="0,0,4,2" Cursor="Hand">
                                                    <TextBlock FontSize="11">
                                                        <Run Text="{Binding FileName, Mode=OneWay}" />
                                                        <Run Text=" (" /><Run Text="{Binding Size, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" /><Run Text=")" />
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- WebView2 for HTML rendering -->
                            <Border>
                                <wpf:WebView2 x:Name="EmailWebView"
                                              xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" />
                            </Border>
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
