<Window x:Class="MailAggregator.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:MailAggregator.Desktop.ViewModels"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="MailAggregator" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Modern Command Bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1"
                Padding="8,6">
            <DockPanel>
                <!-- Right-side actions -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenAccountSettingsCommand}" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Accounts" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{StaticResource SeparatorBrush}" Margin="4,4" />
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenTwoFactorCommand}" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="2FA" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Left-side actions -->
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding ComposeNewCommand}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="New Mail" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource SeparatorBrush}" Margin="8,4" />

                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding ReplyCommand}" ToolTip="Reply" Margin="2,0">
                        <TextBlock Text="&#xE97A;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding ReplyAllCommand}" ToolTip="Reply All" Margin="2,0">
                        <TextBlock Text="&#xE8C2;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding ForwardCommand}" ToolTip="Forward" Margin="2,0">
                        <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource SeparatorBrush}" Margin="8,4" />

                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding DeleteMessageCommand}"
                            CommandParameter="{Binding SelectedEmail}"
                            ToolTip="Delete" Margin="2,0">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="{StaticResource ErrorBrush}" />
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource SeparatorBrush}" Margin="8,4" />

                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding LoadAccountsCommand}" ToolTip="Refresh" Margin="2,0">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Modern Status Bar -->
        <Border DockPanel.Dock="Bottom" Padding="12,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ProgressBar Width="120" Height="3"
                                 IsIndeterminate="True" Margin="0,0,8,0"
                                 Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVisibility}}" />
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding CycleLogLevelCommand}"
                            ToolTip="Click to cycle log level" Padding="6,2" FontSize="11">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEA37;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding LogLevel}" VerticalAlignment="Center" FontSize="11" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource StatusBarText}" />
            </DockPanel>
        </Border>

        <!-- Main three-pane layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Left: Account/Folder tree -->
                <ColumnDefinition Width="240" MinWidth="180" />
                <ColumnDefinition Width="Auto" />
                <!-- Right: Email list + Preview -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel: Folder tree -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Sidebar header -->
                    <Border DockPanel.Dock="Top" Padding="16,12,16,8">
                        <TextBlock Text="ACCOUNTS" Style="{StaticResource SectionHeader}" />
                    </Border>

                    <TreeView x:Name="FolderTreeView" ItemsSource="{Binding FolderTree}"
                              BorderThickness="0" Background="Transparent" Padding="8,0">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" VerticalAlignment="Center" />
                                    <Border Margin="6,0,0,0" Padding="6,1" CornerRadius="8"
                                            Background="{StaticResource PrimaryBrush}"
                                            Visibility="{Binding UnreadCount, Converter={StaticResource NullToVisibility}, FallbackValue=Collapsed}">
                                        <TextBlock Text="{Binding UnreadCount}"
                                                   Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="{StaticResource SeparatorBrush}" />

            <!-- Right panel: Email list + Preview -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1.5*" MinHeight="150" />
                </Grid.RowDefinitions>

                <!-- Email list -->
                <ListBox Grid.Row="0" ItemsSource="{Binding Emails}"
                         SelectedItem="{Binding SelectedEmail}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource EmailListItem}"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                         ScrollViewer.CanContentScroll="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Sender -->
                                <TextBlock Grid.Row="0" Grid.Column="0" FontSize="13"
                                           FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeight}}">
                                    <Run Text="{Binding FromName, Mode=OneWay}" />
                                    <Run Text=" &lt;" Foreground="{StaticResource ReadBrush}" /><Run Text="{Binding FromAddress, Mode=OneWay}" Foreground="{StaticResource ReadBrush}" /><Run Text="&gt;" Foreground="{StaticResource ReadBrush}" />
                                </TextBlock>

                                <!-- Date -->
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding DateSent, StringFormat='{}{0:MM/dd HH:mm}'}"
                                           Foreground="{StaticResource SubtleBrush}" FontSize="12"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />

                                <!-- Subject + Preview -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Foreground="{StaticResource ReadBrush}" FontSize="12"
                                           TextTrimming="CharacterEllipsis" Margin="0,3,0,0">
                                    <Run Text="{Binding Subject, Mode=OneWay}"
                                         FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeight}}" />
                                    <Run Text=" — " Foreground="{StaticResource SubtleBrush}" />
                                    <Run Text="{Binding PreviewText, Mode=OneWay}" Foreground="{StaticResource SubtleBrush}" />
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Horizontal splitter -->
                <GridSplitter Grid.Row="1" Height="1" HorizontalAlignment="Stretch"
                              VerticalAlignment="Center" Background="{StaticResource SeparatorBrush}" />

                <!-- Email preview -->
                <Border Grid.Row="2">
                    <Grid>
                        <!-- No email selected -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibility}, ConverterParameter=Invert}">
                            <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                       Foreground="{StaticResource SubtleBrush}" HorizontalAlignment="Center"
                                       Margin="0,0,0,12" />
                            <TextBlock Text="Select an email to preview"
                                       Foreground="{StaticResource ReadBrush}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Email preview content -->
                        <DockPanel Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibility}}">
                            <!-- Email header -->
                            <Border DockPanel.Dock="Top" Padding="16,12"
                                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                    BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedEmail.Subject}"
                                               FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource ReadBrush}">
                                        <Run Text="From: " />
                                        <Run Text="{Binding SelectedEmail.FromName, Mode=OneWay}" />
                                        <Run Text=" &lt;" /><Run Text="{Binding SelectedEmail.FromAddress, Mode=OneWay}" /><Run Text="&gt;" />
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{StaticResource ReadBrush}">
                                        <Run Text="To: " />
                                        <Run Text="{Binding SelectedEmail.ToAddresses, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{StaticResource SubtleBrush}"
                                               Text="{Binding SelectedEmail.DateSent, StringFormat='Date: {0:yyyy-MM-dd HH:mm:ss}'}" />

                                    <!-- Attachments -->
                                    <ItemsControl ItemsSource="{Binding SelectedEmail.Attachments}"
                                                  Margin="0,8,0,0"
                                                  Visibility="{Binding SelectedEmail.HasAttachments, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource CardBorderBrush}"
                                                        Background="{StaticResource CardBrush}"
                                                        BorderThickness="1" CornerRadius="4"
                                                        Padding="8,4" Margin="0,0,6,4" Cursor="Hand">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="12" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource PrimaryBrush}"
                                                                   Margin="0,0,6,0" />
                                                        <TextBlock FontSize="12" VerticalAlignment="Center">
                                                            <Run Text="{Binding FileName, Mode=OneWay}" />
                                                            <Run Text=" (" Foreground="{StaticResource SubtleBrush}" /><Run Text="{Binding Size, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Foreground="{StaticResource SubtleBrush}" /><Run Text=")" Foreground="{StaticResource SubtleBrush}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Remote images blocked notification -->
                            <Border x:Name="RemoteImagesBar" DockPanel.Dock="Top"
                                    Padding="12,8" Background="{StaticResource WarningBackgroundBrush}"
                                    BorderBrush="{StaticResource WarningBorderBrush}" BorderThickness="0,0,0,1"
                                    Visibility="Collapsed">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Load Images"
                                            Click="LoadRemoteImages_Click"
                                            Style="{StaticResource ToolbarButton}"
                                            Foreground="{StaticResource PrimaryBrush}"
                                            FontSize="12" Padding="8,4" />
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14" VerticalAlignment="Center"
                                                   Foreground="{StaticResource WarningTextBrush}" Margin="0,0,8,0" />
                                        <TextBlock Text="Remote images have been blocked to protect your privacy."
                                                   VerticalAlignment="Center" FontSize="12"
                                                   Foreground="{StaticResource WarningTextBrush}" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- WebView2 for HTML rendering -->
                            <wpf:WebView2 x:Name="EmailWebView"
                                          xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" />
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
