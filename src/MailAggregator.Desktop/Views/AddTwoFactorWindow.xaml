<Window x:Class="MailAggregator.Desktop.Views.AddTwoFactorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:models="clr-namespace:MailAggregator.Core.Models;assembly=MailAggregator.Core"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{Binding WindowTitle}" Height="480" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="{Binding WindowTitle}" Style="{StaticResource PageTitle}" />

        <!-- Add mode content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
            <StackPanel>
                <!-- Mode toggle -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton Content="Manual Input" GroupName="InputMode"
                                 IsChecked="True" Margin="0,0,16,0" />
                    <RadioButton Content="Import URI" GroupName="InputMode"
                                 IsChecked="{Binding IsUriMode}" />
                </StackPanel>

                <!-- URI import -->
                <StackPanel Visibility="{Binding IsUriMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="otpauth:// URI" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBox Text="{Binding UriText, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="False"
                             Margin="0,0,0,8" />
                    <Button Content="Parse URI" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ParseUriCommand}"
                            HorizontalAlignment="Left" Margin="0,0,0,16" />
                </StackPanel>

                <!-- Manual input fields -->
                <TextBlock Text="Issuer (e.g. Google, GitHub)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox Text="{Binding Issuer, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />

                <TextBlock Text="Label (e.g. user@example.com)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />

                <StackPanel Visibility="{Binding IsUriMode, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <TextBlock Text="Secret Key (Base32)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBox Text="{Binding Secret, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" Margin="0,0,0,16" />

                    <!-- Advanced settings -->
                    <Expander Header="Advanced Settings" Margin="0,0,0,8">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Algorithm" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ComboBox SelectedItem="{Binding SelectedAlgorithm}" Margin="0,0,0,12">
                                <models:OtpAlgorithm>Sha1</models:OtpAlgorithm>
                                <models:OtpAlgorithm>Sha256</models:OtpAlgorithm>
                                <models:OtpAlgorithm>Sha512</models:OtpAlgorithm>
                            </ComboBox>

                            <TextBlock Text="Digits" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBox Text="{Binding Digits}" Margin="0,0,0,12" />

                            <TextBlock Text="Period (seconds)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBox Text="{Binding Period}" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Edit mode content -->
        <StackPanel Grid.Row="1"
                    Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Issuer" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBox Text="{Binding Issuer, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,16" />

            <TextBlock Text="Label" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,16" />

            <Border Background="{StaticResource SidebarBrush}" CornerRadius="4" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource SubtleBrush}" VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="Secret key cannot be modified." Foreground="{StaticResource SubtleBrush}" FontSize="12" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusText}"
                   Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap"
                   Margin="0,8,0,8"
                   Visibility="{Binding StatusText, Converter={StaticResource NullToVisibility}}" />

        <!-- Buttons -->
        <Border Grid.Row="3" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"
                Padding="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                <Button Content="Cancel" Style="{StaticResource ToolbarButton}"
                        IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
