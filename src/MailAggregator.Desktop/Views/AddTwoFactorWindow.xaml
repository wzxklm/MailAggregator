<Window x:Class="MailAggregator.Desktop.Views.AddTwoFactorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MailAggregator.Core.Models;assembly=MailAggregator.Core"
        Title="{Binding WindowTitle}" Height="460" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="{Binding WindowTitle}"
                   FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />

        <!-- Add mode content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
            <StackPanel>
                <!-- Mode toggle -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton Content="Manual Input" GroupName="InputMode"
                                 IsChecked="True" Margin="0,0,16,0" />
                    <RadioButton Content="Import URI" GroupName="InputMode"
                                 IsChecked="{Binding IsUriMode}" />
                </StackPanel>

                <!-- URI import -->
                <StackPanel Visibility="{Binding IsUriMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="otpauth:// URI:" Margin="0,0,0,4" />
                    <TextBox Text="{Binding UriText, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="False"
                             Padding="8,6" Margin="0,0,0,8" />
                    <Button Content="Parse URI" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ParseUriCommand}"
                            HorizontalAlignment="Left" Margin="0,0,0,12" />
                </StackPanel>

                <!-- Manual input fields -->
                <TextBlock Text="Issuer (e.g. Google, GitHub):" Margin="0,0,0,4" />
                <TextBox Text="{Binding Issuer, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,12" />

                <TextBlock Text="Label (e.g. user@example.com):" Margin="0,0,0,4" />
                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,12" />

                <StackPanel Visibility="{Binding IsUriMode, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <TextBlock Text="Secret Key (Base32):" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Secret, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" Padding="8,6" Margin="0,0,0,12" />

                    <!-- Advanced settings -->
                    <Expander Header="Advanced Settings" Margin="0,0,0,8">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Algorithm:" Margin="0,0,0,4" />
                            <ComboBox SelectedItem="{Binding SelectedAlgorithm}" Margin="0,0,0,8">
                                <models:OtpAlgorithm>Sha1</models:OtpAlgorithm>
                                <models:OtpAlgorithm>Sha256</models:OtpAlgorithm>
                                <models:OtpAlgorithm>Sha512</models:OtpAlgorithm>
                            </ComboBox>

                            <TextBlock Text="Digits:" Margin="0,0,0,4" />
                            <TextBox Text="{Binding Digits}" Padding="8,6" Margin="0,0,0,8" />

                            <TextBlock Text="Period (seconds):" Margin="0,0,0,4" />
                            <TextBox Text="{Binding Period}" Padding="8,6" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Edit mode content -->
        <StackPanel Grid.Row="1"
                    Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Issuer:" Margin="0,0,0,4" />
            <TextBox Text="{Binding Issuer, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" Margin="0,0,0,12" />

            <TextBlock Text="Label:" Margin="0,0,0,4" />
            <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" Margin="0,0,0,12" />

            <TextBlock Text="Secret key cannot be modified." Foreground="Gray" FontSize="12" />
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusText}"
                   Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap"
                   Margin="0,8,0,8"
                   Visibility="{Binding StatusText, Converter={StaticResource NullToVisibility}}" />

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}" Margin="0,0,8,0" />
            <Button Content="Cancel" Style="{StaticResource ToolbarButton}"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
