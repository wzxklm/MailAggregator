<Window x:Class="MailAggregator.Desktop.Views.TwoFactorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Two-Factor Authentication" Height="500" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">

    <DockPanel Margin="12">
        <!-- Bottom: Buttons + Status -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="Gray" FontSize="12"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <Button Content="Add" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddAccountCommand}" Margin="0,0,8,0" />
            <Button Content="Edit" Style="{StaticResource ToolbarButton}"
                    Command="{Binding EditAccountCommand}" Margin="0,0,8,0" />
            <Button Content="Delete" Style="{StaticResource ToolbarButton}"
                    Command="{Binding DeleteAccountCommand}" Foreground="Red" />
        </StackPanel>

        <!-- Account list -->
        <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                 BorderThickness="1" BorderBrush="#DDD"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="8,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Issuer -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Account.Issuer}"
                                   FontWeight="SemiBold" FontSize="14" />

                        <!-- Copy button -->
                        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                Content="Copy" Style="{StaticResource ToolbarButton}"
                                Command="{Binding DataContext.CopyCodeCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                VerticalAlignment="Center" Margin="8,0,0,0" />

                        <!-- Label -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Account.Label}"
                                   Foreground="Gray" FontSize="12" />

                        <!-- Code -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="{Binding CurrentCode}"
                                   FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,4,0,2" />

                        <!-- Progress bar + remaining seconds -->
                        <DockPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding RemainingSeconds, StringFormat='{}{0}s'}"
                                       Foreground="Gray" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                            <ProgressBar Value="{Binding ProgressPercentage, Mode=OneWay}"
                                         Minimum="0" Maximum="100" Height="6"
                                         Foreground="{StaticResource PrimaryBrush}" />
                        </DockPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <!-- Empty state -->
            <ListBox.Style>
                <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Items.Count}" Value="0">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <Border BorderBrush="#DDD" BorderThickness="1">
                                            <TextBlock Text="No 2FA accounts. Click 'Add' to get started."
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="Gray" FontSize="14" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
        </ListBox>
    </DockPanel>
</Window>
