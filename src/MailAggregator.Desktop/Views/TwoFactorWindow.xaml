<Window x:Class="MailAggregator.Desktop.Views.TwoFactorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Two-Factor Authentication" Height="520" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">

    <DockPanel Margin="16">
        <!-- Bottom: Buttons + Status -->
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="0,12,0,0"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}"
                           Foreground="{StaticResource SubtleBrush}" FontSize="12"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Add" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddAccountCommand}" Margin="0,0,8,0" />
                    <Button Content="Edit" Style="{StaticResource ToolbarButton}"
                            Command="{Binding EditAccountCommand}" Margin="0,0,8,0" />
                    <Button Content="Delete" Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteAccountCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Account list -->
        <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                 BorderThickness="1" BorderBrush="{StaticResource CardBorderBrush}"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="4,4" Padding="12,10" CornerRadius="6"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Issuer -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Account.Issuer}"
                                       FontWeight="SemiBold" FontSize="14" />

                            <!-- Copy button -->
                            <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                    ToolTip="Copy Code" Style="{StaticResource ToolbarButton}"
                                    Command="{Binding DataContext.CopyCodeCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"
                                    VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                            </Button>

                            <!-- Label -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Account.Label}"
                                       Foreground="{StaticResource SubtleBrush}" FontSize="12"
                                       Margin="0,2,0,0" />

                            <!-- Code -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding CurrentCode}"
                                       FontSize="32" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,8,0,4" />

                            <!-- Progress bar + remaining seconds -->
                            <DockPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding RemainingSeconds, StringFormat='{}{0}s'}"
                                           Foreground="{StaticResource SubtleBrush}" FontSize="11"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                                <ProgressBar Value="{Binding ProgressPercentage, Mode=OneWay}"
                                             Minimum="0" Maximum="100" Height="4" />
                            </DockPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <!-- Empty state -->
            <ListBox.Style>
                <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Items.Count}" Value="0">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="36" Foreground="{StaticResource SubtleBrush}"
                                                           HorizontalAlignment="Center" Margin="0,0,0,12" />
                                                <TextBlock Text="No 2FA accounts"
                                                           FontSize="16" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                                                <TextBlock Text="Click 'Add' to get started."
                                                           Foreground="{StaticResource SubtleBrush}" FontSize="13"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
        </ListBox>
    </DockPanel>
</Window>
