<Window x:Class="MailAggregator.Desktop.Views.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{Binding WindowTitle}" Height="520" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <!-- Step 0: Email input -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="Add Email Account" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Enter your email address to get started" FontSize="14"
                       Foreground="{StaticResource ReadBrush}" Margin="0,0,0,16" />
            <TextBlock Text="Email Address" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBox Text="{Binding EmailAddress, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="14" Margin="0,0,0,20" />
            <Button Content="Continue" Style="{StaticResource PrimaryButton}"
                    Command="{Binding DiscoverCommand}" HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Step 1: Discovery in progress -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="Discovering Server..." Style="{StaticResource PageTitle}" />
            <ui:ProgressRing IsActive="True" Width="48" Height="48" Margin="0,0,0,16" />
            <TextBlock Text="{Binding DiscoveryStatus}" TextWrapping="Wrap"
                       Foreground="{StaticResource ReadBrush}" FontSize="13" />
            <Button Content="Skip — Configure Manually" Style="{StaticResource ToolbarButton}"
                    Command="{Binding SkipDiscoveryCommand}" Margin="0,20,0,0" HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Step 2: Auth selection -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="Authentication" Style="{StaticResource PageTitle}" />

            <!-- Discovery result (only when auto-discovery succeeded) -->
            <Border Background="{StaticResource SuccessBackgroundBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,0,16"
                    Visibility="{Binding IsDiscoverySucceeded, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource SuccessTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding DiscoveryStatus}" Foreground="{StaticResource SuccessTextBrush}" FontSize="13" />
                </StackPanel>
            </Border>

            <RadioButton Content="OAuth 2.0 (Recommended)" GroupName="Auth"
                         IsChecked="{Binding IsOAuthSelected, Mode=TwoWay}"
                         IsEnabled="{Binding IsOAuthAvailable}" Margin="0,0,0,10" />
            <RadioButton Content="Password / App Password" GroupName="Auth"
                         IsChecked="{Binding IsPasswordSelected, Mode=OneWay}" Margin="0,0,0,16" />

            <TextBlock Text="Password" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"
                       Visibility="{Binding IsPasswordSelected, Converter={StaticResource BoolToVisibility}}" />
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,16"
                         Visibility="{Binding IsPasswordSelected, Converter={StaticResource BoolToVisibility}}" />

            <!-- OAuth status -->
            <Border Background="{StaticResource InfoBackgroundBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding OAuthStatus, Converter={StaticResource NullToVisibility}}">
                <TextBlock Text="{Binding OAuthStatus}" Foreground="{StaticResource PrimaryBrush}"
                           TextWrapping="Wrap" FontSize="13" />
            </Border>

            <!-- Error message -->
            <Border Background="{StaticResource ErrorBackgroundBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap" FontSize="13" />
            </Border>

            <Border BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"
                    Padding="0,12,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Connect" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Back" Style="{StaticResource ToolbarButton}"
                                Command="{Binding GoBackCommand}" Margin="0,0,8,0" />
                        <Button Content="Server Settings" Style="{StaticResource ToolbarButton}"
                                Command="{Binding GoToServerConfigCommand}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <ProgressBar IsIndeterminate="True" Height="3" Margin="0,12,0,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <!-- Step 3: Manual server config -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>
                <TextBlock Text="Server Configuration" Style="{StaticResource PageTitle}" />

                <!-- IMAP -->
                <TextBlock Text="IMAP SERVER" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ImapHost}"
                             ui:ControlHelper.PlaceholderText="Host" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding ImapPort}"
                             ui:ControlHelper.PlaceholderText="Port" />
                </Grid>
                <ComboBox SelectedIndex="{Binding ImapEncryption}" Margin="0,0,0,20"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="SSL/TLS" />
                    <ComboBoxItem Content="STARTTLS" />
                </ComboBox>

                <!-- SMTP -->
                <TextBlock Text="SMTP SERVER" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SmtpHost}"
                             ui:ControlHelper.PlaceholderText="Host" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding SmtpPort}"
                             ui:ControlHelper.PlaceholderText="Port" />
                </Grid>
                <ComboBox SelectedIndex="{Binding SmtpEncryption}" Margin="0,0,0,20"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="SSL/TLS" />
                    <ComboBoxItem Content="STARTTLS" />
                </ComboBox>

                <!-- Proxy -->
                <TextBlock Text="SOCKS5 PROXY (OPTIONAL)" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ProxyHost}"
                             ui:ControlHelper.PlaceholderText="Host" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding ProxyPort}"
                             ui:ControlHelper.PlaceholderText="Port" />
                </Grid>

                <!-- Error message -->
                <Border Background="{StaticResource ErrorBackgroundBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap" FontSize="13" />
                </Border>

                <!-- Buttons -->
                <Border BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"
                        Padding="0,12,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Back" Style="{StaticResource ToolbarButton}"
                                Command="{Binding GoBackCommand}" Margin="0,0,8,0" />
                        <!-- Edit mode: save directly; New account: go to auth step for password -->
                        <Button Content="Save" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}" />
                        <Button Content="Next" Style="{StaticResource PrimaryButton}"
                                Command="{Binding GoToAuthCommand}"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                    </StackPanel>
                </Border>

                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,12,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Step 4: Complete -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <Border HorizontalAlignment="Center" Margin="0,40,0,20">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="32"
                            Background="{StaticResource SuccessBackgroundBrush}" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="{StaticResource SuccessTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Account Added!" FontSize="22" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="Your account has been configured successfully."
                               Foreground="{StaticResource ReadBrush}" FontSize="14"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
