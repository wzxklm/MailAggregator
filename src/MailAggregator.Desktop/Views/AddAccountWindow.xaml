<Window x:Class="MailAggregator.Desktop.Views.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="500" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <!-- Step 0: Email input -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="Add Email Account" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" />
            <TextBlock Text="Enter your email address to get started:" Margin="0,0,0,8" />
            <TextBox Text="{Binding EmailAddress, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="14" Padding="8,6" Margin="0,0,0,16" />
            <Button Content="Continue" Style="{StaticResource PrimaryButton}"
                    Command="{Binding DiscoverCommand}" HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Step 1: Discovery in progress -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="Discovering Server..." FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" />
            <ProgressBar IsIndeterminate="True" Height="20" Margin="0,0,0,12" />
            <TextBlock Text="{Binding DiscoveryStatus}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Step 2: Auth selection -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="Authentication" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" />
            <TextBlock Text="{Binding DiscoveryStatus}" Foreground="Green" Margin="0,0,0,12" />

            <RadioButton Content="OAuth 2.0 (Recommended)" GroupName="Auth"
                         IsChecked="{Binding IsOAuthAvailable}"
                         IsEnabled="{Binding IsOAuthAvailable}" Margin="0,0,0,8" />
            <RadioButton Content="Password / App Password" GroupName="Auth" Margin="0,0,0,12" />

            <TextBlock Text="Password:" Margin="0,0,0,4" />
            <PasswordBox x:Name="PasswordBox" Padding="8,6" Margin="0,0,0,16" />

            <StackPanel Orientation="Horizontal">
                <Button Content="Back" Style="{StaticResource ToolbarButton}"
                        Command="{Binding GoBackCommand}" Margin="0,0,8,0" />
                <Button Content="Server Settings" Style="{StaticResource ToolbarButton}"
                        Command="{Binding GoToServerConfigCommand}" Margin="0,0,8,0" />
                <Button Content="Connect" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- Step 3: Manual server config -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>
                <TextBlock Text="Server Configuration" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />

                <!-- IMAP -->
                <TextBlock Text="IMAP Server" FontWeight="SemiBold" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ImapHost}" Padding="6,4" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding ImapPort}" Padding="6,4" />
                </Grid>
                <ComboBox SelectedIndex="{Binding ImapEncryption}" Margin="0,0,0,12">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="SSL/TLS" />
                    <ComboBoxItem Content="STARTTLS" />
                </ComboBox>

                <!-- SMTP -->
                <TextBlock Text="SMTP Server" FontWeight="SemiBold" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SmtpHost}" Padding="6,4" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding SmtpPort}" Padding="6,4" />
                </Grid>
                <ComboBox SelectedIndex="{Binding SmtpEncryption}" Margin="0,0,0,12">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="SSL/TLS" />
                    <ComboBoxItem Content="STARTTLS" />
                </ComboBox>

                <!-- Proxy -->
                <TextBlock Text="SOCKS5 Proxy (Optional)" FontWeight="SemiBold" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ProxyHost}" Padding="6,4" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding ProxyPort}" Padding="6,4" />
                </Grid>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}" />

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Back" Style="{StaticResource ToolbarButton}"
                            Command="{Binding GoBackCommand}" Margin="0,0,8,0" />
                    <Button Content="Save" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}" />
                </StackPanel>

                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,12,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Step 4: Complete -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="Account Added!" FontSize="20" FontWeight="SemiBold"
                       Foreground="Green" Margin="0,0,0,12" />
            <TextBlock Text="Your account has been configured successfully." Margin="0,0,0,20" />
        </StackPanel>
    </Grid>
</Window>
