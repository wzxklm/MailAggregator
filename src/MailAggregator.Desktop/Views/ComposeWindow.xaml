<Window x:Class="MailAggregator.Desktop.Views.ComposeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{Binding WindowTitle}" Height="580" Width="680"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Top: Command bar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding SendCommand}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Send" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="{Binding AddAttachmentCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Attach" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Bottom: Status -->
        <Border DockPanel.Dock="Bottom" Padding="16,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <ProgressBar DockPanel.Dock="Right" Width="120" Height="3"
                             IsIndeterminate="True" Margin="12,0,0,0"
                             Visibility="{Binding IsSending, Converter={StaticResource BoolToVisibility}}" />
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource SubtleBrush}" FontSize="12" />
            </DockPanel>
        </Border>

        <!-- Form -->
        <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- From -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="From" VerticalAlignment="Center"
                       FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource ReadBrush}" Margin="0,0,0,8" />
            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding SenderAccounts}"
                      SelectedItem="{Binding SelectedSender}" DisplayMemberPath="EmailAddress"
                      HorizontalAlignment="Stretch" Margin="0,0,0,8" />

            <!-- To -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="To" VerticalAlignment="Center"
                       FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource ReadBrush}" Margin="0,0,0,8" />
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding To}" Margin="0,0,0,8" />

            <!-- Cc -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Cc" VerticalAlignment="Center"
                       FontSize="13" Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,8" />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Cc}" Margin="0,0,0,8" />

            <!-- Bcc -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Bcc" VerticalAlignment="Center"
                       FontSize="13" Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,8" />
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Bcc}" Margin="0,0,0,8" />

            <!-- Subject -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Subject" VerticalAlignment="Center"
                       FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource ReadBrush}" Margin="0,0,0,8" />
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Subject}"
                     FontWeight="SemiBold" Margin="0,0,0,8" />

            <!-- Attachments -->
            <ItemsControl Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                          ItemsSource="{Binding AttachmentPaths}" Margin="0,0,0,8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SidebarBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8,4" Margin="0,0,6,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding}" FontSize="12" VerticalAlignment="Center" />
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                        FontSize="9" Margin="8,0,0,0"
                                        Command="{Binding DataContext.RemoveAttachmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ToolbarButton}" Padding="4,2" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Body -->
            <TextBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                     Text="{Binding Body}" AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     FontFamily="Segoe UI" FontSize="13" />
        </Grid>
    </DockPanel>
</Window>
