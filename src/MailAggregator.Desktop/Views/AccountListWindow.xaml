<Window x:Class="MailAggregator.Desktop.Views.AccountListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Management" Height="450" Width="600"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="12">
        <!-- Bottom: Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Add Account" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddAccountCommand}" Margin="0,0,8,0" />
            <Button Content="Edit" Style="{StaticResource ToolbarButton}"
                    Command="{Binding EditAccountCommand}" Margin="0,0,8,0" />
            <Button Content="Delete" Style="{StaticResource ToolbarButton}"
                    Command="{Binding DeleteAccountCommand}" Foreground="Red" />
        </StackPanel>

        <!-- Status bar -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}"
                   Foreground="Gray" FontSize="12" Margin="0,8,0,0" />

        <!-- Account list -->
        <ListBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}"
                 BorderThickness="1" BorderBrush="#DDD">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="8,4">
                        <TextBlock Text="{Binding EmailAddress}" FontWeight="SemiBold" FontSize="14" />
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding ImapHost}" Foreground="Gray" FontSize="12" />
                            <TextBlock Text=" | " Foreground="Gray" FontSize="12" />
                            <TextBlock Text="{Binding AuthType}" Foreground="Gray" FontSize="12" />
                            <TextBlock Text=" | " Foreground="Gray" FontSize="12" />
                            <TextBlock FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Enabled" />
                                        <Setter Property="Foreground" Value="Green" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="Text" Value="Disabled" />
                                                <Setter Property="Foreground" Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
